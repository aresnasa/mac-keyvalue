<Window x:Class="KeyValueWin.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:KeyValueWin.Helpers"
        Title="Password Required" Width="360" Height="170"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}">
  <StackPanel Margin="24" h:StackPanelHelper.Spacing="14">
    <TextBlock x:Name="PromptText" Text="Enter password:" FontSize="13"
               Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
    <PasswordBox x:Name="PwdBox" FontSize="14" Padding="8,6"
                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                 KeyDown="OnKeyDown"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" h:StackPanelHelper.Spacing="8">
      <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
              IsCancel="True"/>
      <Button Content="OK" Style="{StaticResource PrimaryButton}"
              IsDefault="True" Click="OnOkClicked"/>
    </StackPanel>
  </StackPanel>
</Window>
