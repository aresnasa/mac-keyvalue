<Window x:Class="KeyValueWin.Views.EntryEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:KeyValueWin.Helpers"
        Title="Entry" Width="480" Height="500" MinHeight="440"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" x:Name="TitleLabel" Text="New Entry"
               FontSize="20" FontWeight="Bold"
               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel h:StackPanelHelper.Spacing="14">

        <StackPanel h:StackPanelHelper.Spacing="5">
          <TextBlock Text="Title *" FontSize="11" FontWeight="SemiBold"
                     Foreground="{StaticResource TextSecondary}"/>
          <TextBox x:Name="TxtTitle" FontSize="13"/>
        </StackPanel>

        <StackPanel h:StackPanelHelper.Spacing="5">
          <TextBlock Text="Username / Account" FontSize="11" FontWeight="SemiBold"
                     Foreground="{StaticResource TextSecondary}"/>
          <TextBox x:Name="TxtKey" FontSize="13"/>
        </StackPanel>

        <StackPanel h:StackPanelHelper.Spacing="5">
          <TextBlock Text="Password / Value *" FontSize="11" FontWeight="SemiBold"
                     Foreground="{StaticResource TextSecondary}"/>
          <Grid>
            <PasswordBox x:Name="PwdValue" FontSize="14" Padding="8,6"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
            <TextBox x:Name="TxtValuePlain" FontSize="13" Visibility="Collapsed"/>
          </Grid>
          <StackPanel Orientation="Horizontal" h:StackPanelHelper.Spacing="6">
            <CheckBox Content="Show password" x:Name="ChkShow"
                      Checked="OnShowPasswordChanged" Unchecked="OnShowPasswordChanged"
                      FontSize="11" Foreground="{StaticResource TextSecondary}"/>
          </StackPanel>
        </StackPanel>

        <StackPanel h:StackPanelHelper.Spacing="5">
          <TextBlock Text="URL / Host" FontSize="11" FontWeight="SemiBold"
                     Foreground="{StaticResource TextSecondary}"/>
          <TextBox x:Name="TxtUrl" FontSize="13"/>
        </StackPanel>

        <StackPanel h:StackPanelHelper.Spacing="5">
          <TextBlock Text="Category" FontSize="11" FontWeight="SemiBold"
                     Foreground="{StaticResource TextSecondary}"/>
          <ComboBox x:Name="CboCategory" FontSize="13"
                    Padding="8,6" BorderBrush="{StaticResource BorderBrush}">
            <ComboBoxItem Content="🔒  Password" Tag="password" IsSelected="True"/>
            <ComboBoxItem Content="📄  Snippet"  Tag="snippet"/>
            <ComboBoxItem Content="📋  Clipboard" Tag="clipboard"/>
            <ComboBoxItem Content="⌨  Command"   Tag="command"/>
            <ComboBoxItem Content="📦  Other"     Tag="other"/>
          </ComboBox>
        </StackPanel>

        <StackPanel h:StackPanelHelper.Spacing="5">
          <TextBlock Text="Tags (comma-separated)" FontSize="11" FontWeight="SemiBold"
                     Foreground="{StaticResource TextSecondary}"/>
          <TextBox x:Name="TxtTags" FontSize="13"/>
        </StackPanel>

        <StackPanel h:StackPanelHelper.Spacing="5">
          <TextBlock Text="Notes" FontSize="11" FontWeight="SemiBold"
                     Foreground="{StaticResource TextSecondary}"/>
          <TextBox x:Name="TxtNotes" FontSize="13" Height="80" TextWrapping="Wrap"
                   AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <CheckBox x:Name="ChkFavorite" Content="⭐  Mark as favorite"
                  FontSize="13" Foreground="{StaticResource TextPrimary}"/>
        <CheckBox x:Name="ChkPrivate"  Content="🔒  Private entry"
                  FontSize="13" Foreground="{StaticResource TextPrimary}"/>
      </StackPanel>
    </ScrollViewer>

    <!-- Buttons -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                h:StackPanelHelper.Spacing="8" Margin="0,16,0,0">
      <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
              IsCancel="True"/>
      <Button Content="Save" Style="{StaticResource PrimaryButton}"
              IsDefault="True" Click="OnSaveClicked"/>
    </StackPanel>
  </Grid>
</Window>
