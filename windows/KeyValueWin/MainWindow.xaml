<Window x:Class="KeyValueWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:KeyValueWin.ViewModels"
        xmlns:conv="clr-namespace:KeyValueWin.Converters"
        xmlns:h="clr-namespace:KeyValueWin.Helpers"
        Title="KeyValue for Windows" Height="640" Width="920" MinWidth="720" MinHeight="480"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <conv:NullToVisibilityConverter   x:Key="NullVis"/>
    <conv:BoolToVisibilityConverter   x:Key="BoolVis"/>
    <conv:InvertBoolConverter         x:Key="InvertBool"/>
    <conv:InvertVisibilityConverter   x:Key="InvertVis"/>
    <conv:BoolToFavoriteStarConverter x:Key="BoolStar"/>
    <conv:IntToVisibilityConverter    x:Key="IntVis"/>
    <DropShadowEffect x:Key="CardShadow" BlurRadius="24" ShadowDepth="4"
                      Direction="270" Color="#20000000" Opacity="0.35"/>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="52"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- ── Data Recovery Banner (shown when IsDataRecovery = true) ── -->
    <Border Grid.Row="0" Grid.RowSpan="4" Panel.ZIndex="100"
            Background="#CC1C1C1E"
            Visibility="{Binding IsDataRecovery, Converter={StaticResource BoolVis}}">
      <Border Background="White" CornerRadius="12" MaxWidth="600" MaxHeight="560"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              Padding="32" Effect="{StaticResource CardShadow}">
        <StackPanel>
          <!-- Icon + title -->
          <TextBlock Text="⚠️  Data Recovery Required" FontSize="22" FontWeight="SemiBold"
                     Foreground="#FF9500" HorizontalAlignment="Center" Margin="0,0,0,12"/>

          <!-- Reason -->
          <Border Background="#FFF3E3" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <TextBlock Text="{Binding RecoveryReason}" FontSize="13" TextWrapping="Wrap"
                       Foreground="#6B4C00" LineHeight="22"/>
          </Border>

          <!-- Data folder path -->
          <TextBlock Text="Data folder:" FontSize="12" Foreground="Gray" Margin="0,0,0,4"/>
          <Border Background="#F2F2F7" CornerRadius="6" Padding="10,6" Margin="0,0,0,20">
            <TextBlock Text="{Binding RecoveryDataFolder}" FontSize="12" FontFamily="Consolas"
                       Foreground="#333" TextWrapping="Wrap"/>
          </Border>

          <!-- Action buttons -->
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
            <Button Style="{StaticResource SecondaryButton}" Content="📂  Open Data Folder"
                    Command="{Binding OpenDataFolderCommand}" Margin="0,0,10,0"/>
            <Button Style="{StaticResource SecondaryButton}" Content="🔄  Retry"
                    Command="{Binding RetryInitializeCommand}" Margin="0,0,10,0"/>
            <Button Background="#FF3B30" Foreground="White" FontSize="13" FontWeight="Medium"
                    Padding="16,7" BorderThickness="0" Cursor="Hand"
                    Command="{Binding PerformDataResetCommand}"
                    ToolTip="⚠️ This will permanently delete all data and create a fresh encryption key">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}" CornerRadius="8"
                          Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter Property="Background" Value="#C0392B"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
              <TextBlock Text="🗑  Reset All Data" Foreground="White" FontSize="13"/>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

    <!-- ── Toolbar ── -->
    <Border Grid.Row="0" Background="White"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
            Padding="14,0">
      <DockPanel VerticalAlignment="Center">

        <!-- Right side buttons -->
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"
                  Content="⬇  Import" Command="{Binding ImportFileCommand}"
                  ToolTip="Import from CSV, JSON, Bitwarden, or encrypted .mkve"/>
          <Menu Background="Transparent" VerticalAlignment="Center" Margin="0,0,6,0">
            <MenuItem Header="⬆  Export" FontSize="13" Padding="14,5"
                      Foreground="{StaticResource AccentBrush}" Cursor="Hand">
              <MenuItem Header="Export as JSON (.json)"        Command="{Binding ExportJsonCommand}"/>
              <MenuItem Header="Export Encrypted (.mkve)"      Command="{Binding ExportEncryptedCommand}"/>
              <MenuItem Header="Export as CSV (.csv)"          Command="{Binding ExportCsvCommand}"/>
            </MenuItem>
          </Menu>
          <Button Style="{StaticResource PrimaryButton}" Content="＋  New Entry"
                  Click="OnNewEntryClicked"/>
        </StackPanel>

        <!-- Search box -->
        <Border Background="#F2F2F7" CornerRadius="8" Padding="10,0"
                MaxWidth="300" VerticalAlignment="Center" Height="32">
          <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="🔍" VerticalAlignment="Center"
                       Margin="0,0,6,0" Foreground="{StaticResource TextSecondary}"/>
            <TextBox Background="Transparent" BorderThickness="0" FontSize="13"
                     VerticalAlignment="Center"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Width="230">
              <TextBox.Style>
                <Style TargetType="TextBox">
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </TextBox.Style>
            </TextBox>
          </DockPanel>
        </Border>
      </DockPanel>
    </Border>

    <!-- ── Two-pane content ── -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="270" MinWidth="180" MaxWidth="380"/>
        <ColumnDefinition Width="5"/>
        <ColumnDefinition Width="*" MinWidth="300"/>
      </Grid.ColumnDefinitions>

      <!-- Entry list -->
      <Border Grid.Column="0" Background="White"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
        <Grid>
          <!-- Empty state -->
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                      h:StackPanelHelper.Spacing="8"
                      Visibility="{Binding FilteredEntries.Count, Converter={StaticResource IntVis}, ConverterParameter=empty}">
            <TextBlock Text="🔒" FontSize="40" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextSecondary}"/>
            <TextBlock Text="No entries yet" FontSize="13"
                       Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
            <Button Style="{StaticResource PrimaryButton}" Content="＋ Add First Entry"
                    Click="OnNewEntryClicked" HorizontalAlignment="Center" Margin="0,4,0,0"/>
          </StackPanel>

          <ListBox ItemsSource="{Binding FilteredEntries}"
                   SelectedItem="{Binding SelectedEntry}"
                   BorderThickness="0" Background="Transparent" Padding="6"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   Visibility="{Binding FilteredEntries.Count, Converter={StaticResource IntVis}, ConverterParameter=notempty}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                  <Border Width="30" Height="30" CornerRadius="7"
                          Background="{StaticResource AccentLightBrush}"
                          VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="{Binding CategoryIcon}" FontSize="15"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource TextPrimary}" MaxWidth="180"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}"
                               MaxWidth="180" TextTrimming="CharacterEllipsis">
                      <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}">
                          <Binding Path="Key"/>
                        </MultiBinding>
                      </TextBlock.Text>
                    </TextBlock>
                  </StackPanel>
                  <TextBlock Text="⭐" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Top"
                             Visibility="{Binding IsFavorite, Converter={StaticResource BoolVis}}"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="Margin"     Value="0,1"/>
                <Setter Property="Padding"    Value="8,6"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                      <Border Background="{TemplateBinding Background}"
                              CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected"   Value="True">
                          <Setter Property="Background" Value="{StaticResource AccentLightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Background" Value="#EFEFEF"/>
                        </Trigger>
                        <MultiTrigger>
                          <MultiTrigger.Conditions>
                            <Condition Property="IsSelected"   Value="True"/>
                            <Condition Property="IsMouseOver" Value="True"/>
                          </MultiTrigger.Conditions>
                          <Setter Property="Background" Value="#C5DCFA"/>
                        </MultiTrigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </ListBox.ItemContainerStyle>
          </ListBox>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                    Background="Transparent" Cursor="SizeWE" ResizeDirection="Columns"/>

      <!-- ── Detail pane ── -->
      <ScrollViewer Grid.Column="2" Padding="28,22" VerticalScrollBarVisibility="Auto">
        <Grid>

          <!-- Nothing selected -->
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                      h:StackPanelHelper.Spacing="10"
                      Visibility="{Binding SelectedEntry, Converter={StaticResource NullVis}, ConverterParameter=isnull}">
            <TextBlock Text="🔒" FontSize="52" HorizontalAlignment="Center"
                       Foreground="#CCCCCC"/>
            <TextBlock Text="Select an entry to view details"
                       FontSize="14" Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Entry detail -->
          <StackPanel h:StackPanelHelper.Spacing="18"
                      Visibility="{Binding SelectedEntry, Converter={StaticResource NullVis}, ConverterParameter=notnull}">

            <!-- Title + actions row -->
            <DockPanel>
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                          h:StackPanelHelper.Spacing="6" VerticalAlignment="Top">
                <Button Style="{StaticResource SecondaryButton}" Content="✏  Edit"
                        Click="OnEditEntryClicked"/>
                <Button Style="{StaticResource SecondaryButton}"
                        Content="{Binding SelectedEntry.IsFavorite, Converter={StaticResource BoolStar}}"
                        Command="{Binding ToggleFavoriteCommand}"/>
                <Button Style="{StaticResource DangerButton}" Content="✕  Delete"
                        Command="{Binding DeleteEntryCommand}"/>
              </StackPanel>
              <StackPanel>
                <TextBlock Text="{Binding SelectedEntry.Title}" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0">
                  <Run Text="{Binding SelectedEntry.CategoryDisplayName}"/>
                  <Run Text=" · "/>
                  <Run Text="{Binding SelectedEntry.CategoryIcon}"/>
                </TextBlock>
              </StackPanel>
            </DockPanel>

            <!-- Info fields -->
            <Border Background="{StaticResource BgBrush}" CornerRadius="10" Padding="16,14">
              <StackPanel h:StackPanelHelper.Spacing="14">
                <!-- Username / Key -->
                <Grid Visibility="{Binding SelectedEntry.Key, Converter={StaticResource NullVis}, ConverterParameter=notempty}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="Username / Key"
                             FontSize="11" FontWeight="SemiBold"
                             Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding SelectedEntry.Key}"
                             FontSize="13" Foreground="{StaticResource TextPrimary}"
                             TextWrapping="Wrap"/>
                </Grid>

                <!-- URL -->
                <Grid Visibility="{Binding SelectedEntry.Url, Converter={StaticResource NullVis}, ConverterParameter=notempty}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="URL / Host"
                             FontSize="11" FontWeight="SemiBold"
                             Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding SelectedEntry.Url}"
                             FontSize="13" Foreground="{StaticResource AccentBrush}"
                             TextWrapping="Wrap" Cursor="Hand" MouseLeftButtonUp="OnUrlClicked"/>
                </Grid>

                <!-- Notes -->
                <Grid Visibility="{Binding SelectedEntry.Notes, Converter={StaticResource NullVis}, ConverterParameter=notempty}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="Notes"
                             FontSize="11" FontWeight="SemiBold"
                             Foreground="{StaticResource TextSecondary}" VerticalAlignment="Top"
                             Margin="0,2,0,0"/>
                  <TextBlock Grid.Column="1" Text="{Binding SelectedEntry.Notes}"
                             FontSize="13" Foreground="{StaticResource TextPrimary}"
                             TextWrapping="Wrap"/>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Password area -->
            <Border Background="{StaticResource BgBrush}" CornerRadius="10" Padding="16,14">
              <StackPanel h:StackPanelHelper.Spacing="10">
                <TextBlock Text="PASSWORD / VALUE" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondary}"/>
                <Border Background="White" CornerRadius="6" Padding="12,8"
                        Visibility="{Binding IsDecrypted, Converter={StaticResource BoolVis}}">
                  <TextBlock Text="{Binding DecryptedValue}" FontFamily="Consolas" FontSize="15"
                             Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                </Border>
                <TextBlock Text="•••••••••••••" FontSize="24" Foreground="#AAAAAA"
                           Visibility="{Binding IsDecrypted, Converter={StaticResource InvertVis}}"/>
                <StackPanel Orientation="Horizontal" h:StackPanelHelper.Spacing="8">
                  <Button Style="{StaticResource SecondaryButton}" Content="👁  Reveal"
                          Command="{Binding DecryptValueCommand}"
                          Visibility="{Binding IsDecrypted, Converter={StaticResource InvertVis}}"/>
                  <Button Style="{StaticResource SecondaryButton}" Content="🙈  Hide"
                          Command="{Binding HideValueCommand}"
                          Visibility="{Binding IsDecrypted, Converter={StaticResource BoolVis}}"/>
                  <Button Style="{StaticResource PrimaryButton}" Content="📋  Copy to Clipboard"
                          Command="{Binding CopyValueCommand}"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Tags -->
            <WrapPanel Visibility="{Binding SelectedEntry.Tags.Count, Converter={StaticResource IntVis}, ConverterParameter=notempty}">
              <TextBlock Text="Tags: " FontSize="12"
                         Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
              <ItemsControl ItemsSource="{Binding SelectedEntry.Tags}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{StaticResource AccentLightBrush}" CornerRadius="4"
                            Padding="8,3" Margin="4,2">
                      <TextBlock Text="{Binding}" FontSize="11"
                                 Foreground="{StaticResource AccentBrush}"/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </WrapPanel>

          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Grid>

    <!-- ── Status bar ── -->
    <Border Grid.Row="2" Background="White"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
            Padding="14,5"
            Visibility="{Binding IsStatusVisible, Converter={StaticResource BoolVis}}">
      <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                 Foreground="{StaticResource TextSecondary}"/>
    </Border>
  </Grid>

</Window>
